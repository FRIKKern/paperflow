#!/usr/bin/env bash
# paperflow-preflight — runtime preflight for the HTTP services skills depend on.
# Probes 8765 (docs-livereload, always LaunchAgent) and 8767 (paperflow-daemon,
# the single host-scoped daemon that subsumed the old per-instance bridge +
# aux daemon per Goal paperflow-du4). On failure, attempts ONE auto-repair
# via launchctl kickstart, re-probes, then emits one-line JSON to stdout and
# exits 2. On success, exits 0 silently. Exit 1 reserved for script-internal
# errors. Output contract: stdout is empty on success, single-line JSON on
# failure.

set -u

ID="$(id -u)"
LABEL_PREFIX="${LABEL_PREFIX:-dev.${USER}}"
DAEMON_LABEL="${LABEL_PREFIX}.paperflow-daemon"

# ── tolerant HTTP probe (matches install.sh self-test) ─────────────
probe_port() {
    local port="$1"
    curl -fsS --max-time 2 -o /dev/null "http://127.0.0.1:$port/" 2>/dev/null \
        || curl -sS  --max-time 2 -o /dev/null -w '%{http_code}' "http://127.0.0.1:$port/" 2>/dev/null \
            | grep -qE '^[0-9]{3}$'
}

# ── label discovery via launchctl list + awk ───────────────────────
discover_label() {
    local pattern="$1"
    launchctl list 2>/dev/null | awk -v p="$pattern" '$3 ~ p {print $3; exit}'
}

# ── poll a port for up to N seconds (1s steps) ─────────────────────
wait_for_port() {
    local port="$1" max="$2" i=0
    while [ "$i" -lt "$max" ]; do
        if probe_port "$port"; then return 0; fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

# ── JSON string-escape: backslash, quote, control chars → \uXXXX ───
# Reads stdin, writes one escaped JSON-string fragment (no surrounding quotes).
json_escape() {
    python3 -c 'import json,sys; sys.stdout.write(json.dumps(sys.stdin.read())[1:-1])' 2>/dev/null \
        || awk 'BEGIN{ORS=""} {
            gsub(/\\/, "\\\\")
            gsub(/"/,  "\\\"")
            gsub(/\t/, "\\t")
            gsub(/\r/, "\\r")
            gsub(/\n/, "\\n")
            print
        }'
}

# ── tail a logfile, escape, return on stdout ───────────────────────
log_tail_escaped() {
    local path="$1"
    if [ -n "$path" ] && [ -f "$path" ]; then
        tail -n 5 "$path" 2>/dev/null | json_escape
    fi
}

# ── emit failure JSON and exit 2 ───────────────────────────────────
# $7 (supervisor) is optional; defaults to "none" when omitted (e.g. for the
# docs-livereload leg, which is always a LaunchAgent).
emit_failure() {
    local service="$1" port="$2" mode="$3" reason="$4" repair="$5" log_tail="$6"
    local supervisor="${7:-none}"
    local repair_esc
    repair_esc="$(printf '%s' "$repair" | json_escape)"
    printf '{"ok":false,"service":"%s","port":%s,"mode":"%s","supervisor":"%s","reason":"%s","repair_command":"%s","log_tail":"%s"}\n' \
        "$service" "$port" "$mode" "$supervisor" "$reason" "$repair_esc" "$log_tail"
    exit 2
}

# ── 1. 8765 — docs-livereload (always LaunchAgent) ─────────────────
if ! probe_port 8765; then
    LR_LOG_TAIL="$(log_tail_escaped "$HOME/.local/log/docs-livereload.err.log")"
    LR_LABEL="$(discover_label '\.docs-livereload$')"
    if [ -z "$LR_LABEL" ]; then
        emit_failure "docs-livereload" 8765 "launchagent" "label_missing" \
                     "bash install.sh   # LaunchAgent not loaded; rerun installer" \
                     "$LR_LOG_TAIL" "launchd"
    fi
    launchctl kickstart -k "gui/$ID/$LR_LABEL" >/dev/null 2>&1 || true
    sleep 1
    if ! probe_port 8765; then
        LR_LOG_TAIL="$(log_tail_escaped "$HOME/.local/log/docs-livereload.err.log")"
        emit_failure "docs-livereload" 8765 "launchagent" "down" \
                     "launchctl kickstart -k gui/$ID/$LR_LABEL" \
                     "$LR_LOG_TAIL" "launchd"
    fi
fi

# ── 2. 8767 — paperflow-daemon (single host-scoped daemon) ─────────
# Replaces the old aux-daemon + per-instance claude-bridge probes (paperflow-du4).
# Supervisor is now dynamic: cmux workspace, launchd LaunchAgent, or none.
# Detection mirrors paperflow-doctor (spec §3 daemon-supervisor-contract);
# we keep it inline rather than extracting because preflight must remain
# self-contained (it's the Step-0 probe every skill calls).
if ! probe_port 8767; then
    DM_LOG_TAIL="$(log_tail_escaped "$HOME/.local/log/paperflow-daemon.err.log")"
    DAEMON_SUPERVISOR="none"
    if command -v cmux >/dev/null 2>&1 \
       && cmux list-workspaces 2>/dev/null \
            | awk '{ l=$0; sub(/^[* ]+/,"",l); sub(/^[^ \t]+[ \t]+/,"",l);
                     sub(/[ \t]+\[selected\][ \t]*$/,"",l); sub(/[ \t]+$/,"",l);
                     print l }' \
            | grep -qx 'paperflow-daemon'; then
        DAEMON_SUPERVISOR="cmux"
    elif launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "$DAEMON_LABEL"; then
        DAEMON_SUPERVISOR="launchd"
    fi
    case "$DAEMON_SUPERVISOR" in
        cmux)    DM_REPAIR="$HOME/.local/bin/paperflow-daemon-spawn --force-cmux" ;;
        launchd) DM_REPAIR="launchctl kickstart -k gui/$ID/$DAEMON_LABEL" ;;
        *)       DM_REPAIR="$HOME/.local/bin/paperflow-daemon-spawn" ;;
    esac
    # Best-effort one-shot repair under launchd; cmux/none paths skip the
    # kickstart and let the operator run paperflow-daemon-spawn.
    if [ "$DAEMON_SUPERVISOR" = "launchd" ]; then
        launchctl kickstart -k "gui/$ID/$DAEMON_LABEL" >/dev/null 2>&1 || true
    fi
    # Daemon boot includes a registry.jsonl replay; allow a few seconds.
    if ! wait_for_port 8767 5; then
        DM_LOG_TAIL="$(log_tail_escaped "$HOME/.local/log/paperflow-daemon.err.log")"
        emit_failure "paperflow-daemon" 8767 "$DAEMON_SUPERVISOR" "down" \
                     "$DM_REPAIR" "$DM_LOG_TAIL" "$DAEMON_SUPERVISOR"
    fi
fi

# both up
printf 'paperflow-preflight: ok\n' >&2
exit 0
