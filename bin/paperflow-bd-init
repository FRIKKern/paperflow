#!/usr/bin/env bash
# DEPRECATED 2026-05 (Cut 2): folded into `paperflow-doctor --ensure-bd`.
# This source file is kept for one transition release. install.sh no
# longer deploys it to ~/.local/bin/. Callers should switch to:
#   paperflow-doctor --ensure-bd
# (which emits JSON: {ok, action: "init"|"already_init", db_path, ts}).
#
# Initialise Beads in the current repo if not already done. Idempotent.
#
# Walks up from $PWD to find the nearest git repo root. If <root>/.beads/
# does NOT exist, runs `bd init` from that root. If it already exists,
# prints a `•` line and exits 0.
#
# Safe to invoke any number of times.
set -euo pipefail

# Find the nearest git repo root, falling back to $PWD if not in a git tree.
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

if [ -d "$repo_root/.beads" ]; then
    printf '  \033[1;33m•\033[0m .beads already initialized at %s\n' "$repo_root/.beads"
    exit 0
fi

# bd init writes into $PWD, so cd first.
( cd "$repo_root" && bd init )
printf '  \033[1;32m✓\033[0m initialised Beads at %s/.beads\n' "$repo_root"
