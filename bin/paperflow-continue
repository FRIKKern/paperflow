#!/usr/bin/env bash
# paperflow-continue — spawn a fresh Claude Code session in a new terminal tab
# pre-loaded with a Goal's (or legacy mission's) resume_prompt.
# Phase 1: tmux + iTerm + Apple Terminal.
#
# Usage:
#   paperflow-continue <slug>
#   paperflow-continue --dry-run <slug>
#   paperflow-continue --bind-doc <doc_path> [--goal-id <id>] <slug>
#   paperflow-continue --workspace <id> [other flags] <slug>
#
# Flags:
#   --dry-run            Print the resolved command (and resume_prompt) without
#                        spawning a new terminal tab.
#   --bind-doc <path>    Augment the resume_prompt to rebind an orphaned doc to
#                        the new session's bridge daemon. <path> is either
#                        absolute or relative to ~/docs/paperflow/.
#   --goal-id <id>       Optional Goal ID context, surfaced inside the
#                        augmented resume_prompt alongside --bind-doc.
#   --workspace <id>     Prefer spawning a new cmux surface inside the named
#                        cmux workspace. Used by the aux-daemon's
#                        spawn-continuation path so the rebound doc lands in
#                        the same workspace as its dead session. Falls back to
#                        the tmux/iTerm/Terminal cascade when cmux is missing
#                        or `cmux new-surface` fails.
#
# Sidecar resolution order:
#   1. ~/docs/paperflow/goals/<slug>/index.json   (Goal — current canonical)
#   2. ~/docs/paperflow/missions/<slug>.json      (legacy mission archive)
#
# Then opens a new tab/window in the current terminal (or falls back to Apple
# Terminal) running:
#   cd ~ && claude --dangerously-skip-permissions <resume_prompt>

set -euo pipefail

DRY_RUN=0
SLUG=""
BIND_DOC=""
GOAL_ID=""
WORKSPACE=""

while [ $# -gt 0 ]; do
    arg="$1"
    case "$arg" in
        --dry-run) DRY_RUN=1 ;;
        -h|--help)
            sed -n '2,22p' "$0"
            exit 0
            ;;
        --bind-doc)
            if [ $# -lt 2 ]; then
                printf '%s requires a value\n' "$arg" >&2
                exit 2
            fi
            BIND_DOC="$2"
            shift
            ;;
        --bind-doc=*)
            BIND_DOC="${arg#--bind-doc=}"
            ;;
        --goal-id)
            if [ $# -lt 2 ]; then
                printf '%s requires a value\n' "$arg" >&2
                exit 2
            fi
            GOAL_ID="$2"
            shift
            ;;
        --goal-id=*)
            GOAL_ID="${arg#--goal-id=}"
            ;;
        --workspace)
            if [ $# -lt 2 ]; then
                printf '%s requires a value\n' "$arg" >&2
                exit 2
            fi
            WORKSPACE="$2"
            shift
            ;;
        --workspace=*)
            WORKSPACE="${arg#--workspace=}"
            ;;
        --*)
            printf 'Unknown flag: %s\n' "$arg" >&2
            exit 2
            ;;
        *)
            if [ -z "$SLUG" ]; then SLUG="$arg"; else
                printf 'Too many positional args (got %s and %s)\n' "$SLUG" "$arg" >&2
                exit 2
            fi
            ;;
    esac
    shift
done

if [ -z "$SLUG" ]; then
    printf 'Usage: paperflow-continue [--dry-run] [--bind-doc <path>] [--goal-id <id>] [--workspace <id>] <slug>\n' >&2
    exit 2
fi

GOAL_JSON="$HOME/docs/paperflow/goals/${SLUG}/index.json"
MISSION_JSON="$HOME/docs/paperflow/missions/${SLUG}.json"
SIDECAR=""
if [ -f "$GOAL_JSON" ]; then
    SIDECAR="$GOAL_JSON"
elif [ -f "$MISSION_JSON" ]; then
    SIDECAR="$MISSION_JSON"
else
    printf 'No sidecar found for slug "%s". Looked at:\n  %s\n  %s\n' "$SLUG" "$GOAL_JSON" "$MISSION_JSON" >&2
    printf 'Run /paperflow:goal snapshot first to write the Goal sidecar.\n' >&2
    exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
    printf 'jq is required (brew install jq)\n' >&2
    exit 1
fi

RESUME_PROMPT="$(jq -r '.resume_prompt // empty' "$SIDECAR")"
if [ -z "$RESUME_PROMPT" ]; then
    printf 'No resume_prompt found in %s\n' "$SIDECAR" >&2
    exit 1
fi

# --bind-doc: append rebind instructions so the new session immediately
# registers the orphaned doc with the freshly-spawned bridge daemon. The
# new session's first action after preflight is to run paperflow-target,
# which POSTs /docs/register against the new daemon's JSONL.
if [ -n "$BIND_DOC" ]; then
    BIND_SUFFIX=$'\n\n'
    if [ -n "$GOAL_ID" ]; then
        BIND_SUFFIX+="Continue work on Goal ${GOAL_ID}; the doc you'll be rebinding is ${BIND_DOC}."$'\n'
    fi
    BIND_SUFFIX+="After paperflow boots in this session, register doc ${BIND_DOC} with the new bridge daemon by running: ~/.local/bin/paperflow-target ${BIND_DOC}"
    RESUME_PROMPT="${RESUME_PROMPT}${BIND_SUFFIX}"
fi

# Shell-escape the resume prompt for a single-quoted bash string.
# Each literal ' becomes '\'' (close-quote, backslash-quote, reopen-quote).
# Using sed avoids the bash parameter-expansion subtleties that bite when
# the replacement itself contains quotes and backslashes.
ESCAPED_PROMPT="$(printf '%s' "$RESUME_PROMPT" | sed "s/'/'\\\\''/g")"

# The command to run inside the new tab. cd ~ first so paths in the prompt
# resolve from a stable cwd. claude --dangerously-skip-permissions takes the
# initial prompt as a single positional arg.
CMD="cd ~ && claude --dangerously-skip-permissions '$ESCAPED_PROMPT'"

# Detect terminal path.
#
# When --workspace is set, prefer cmux: a new surface in the named workspace
# inherits the dead session's workspace context, so the rebound doc lands in
# the same place as the original session. Falls back to the cascade if cmux
# isn't installed or `cmux new-surface` fails.
PATH_TAKEN=""
CMUX_BIN=""
if [ -n "$WORKSPACE" ]; then
    if command -v cmux >/dev/null 2>&1; then
        CMUX_BIN="$(command -v cmux)"
        PATH_TAKEN="cmux"
    fi
fi
if [ -z "$PATH_TAKEN" ]; then
    if [ -n "${TMUX:-}" ]; then
        PATH_TAKEN="tmux"
    elif [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
        PATH_TAKEN="iterm"
    elif [ "${TERM_PROGRAM:-}" = "Apple_Terminal" ]; then
        PATH_TAKEN="apple_terminal"
    else
        PATH_TAKEN="fallback_apple_terminal"
    fi
fi

if [ "$DRY_RUN" -eq 1 ]; then
    printf 'paperflow-continue: dry-run\n'
    printf '  slug          : %s\n' "$SLUG"
    printf '  sidecar       : %s\n' "$SIDECAR"
    printf '  bind-doc      : %s\n' "${BIND_DOC:-<unset>}"
    printf '  goal-id       : %s\n' "${GOAL_ID:-<unset>}"
    printf '  workspace     : %s\n' "${WORKSPACE:-<unset>}"
    printf '  terminal path : %s\n' "$PATH_TAKEN"
    printf '  resume_prompt : %s\n' "$RESUME_PROMPT"
    printf '  command       : %s\n' "$CMD"
    if [ "$PATH_TAKEN" = "cmux" ]; then
        printf '  spawn         : %s new-surface --workspace %s -- %s\n' "$CMUX_BIN" "$WORKSPACE" "$CMD"
    fi
    exit 0
fi

# AppleScript-escape: backslashes and double quotes need doubling/escaping
# inside a "...string..." literal in osascript. We pass our shell command as
# an embedded string, so:
#   \  →  \\
#   "  →  \"
osascript_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    printf '%s' "$s"
}

cmux_fallback_cascade() {
    # Re-detect a fallback path when cmux spawn fails. Skips the cmux branch
    # to avoid an infinite loop.
    if [ -n "${TMUX:-}" ]; then
        PATH_TAKEN="tmux"
    elif [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
        PATH_TAKEN="iterm"
    elif [ "${TERM_PROGRAM:-}" = "Apple_Terminal" ]; then
        PATH_TAKEN="apple_terminal"
    else
        PATH_TAKEN="fallback_apple_terminal"
    fi
    printf 'paperflow-continue: cmux spawn failed, falling back via %s\n' "$PATH_TAKEN" >&2
}

case "$PATH_TAKEN" in
    cmux)
        # Create a new surface in the named workspace, then type the command
        # into it. `cmux new-surface` prints the new surface ref on stdout;
        # we capture it and target it explicitly with `send` / `send-key` so
        # we don't race against whichever surface cmux happens to focus.
        SURFACE_OUT=""
        if ! SURFACE_OUT="$("$CMUX_BIN" new-surface --workspace "$WORKSPACE" 2>&1)"; then
            printf 'paperflow-continue: cmux new-surface failed: %s\n' "$SURFACE_OUT" >&2
            cmux_fallback_cascade
        else
            # First whitespace-separated token of stdout that looks like a
            # surface ref (`surface:N`) wins. If no ref is parsed, target by
            # workspace alone — cmux focuses the new surface by default.
            SURFACE_REF="$(printf '%s\n' "$SURFACE_OUT" | tr -s ' \t\n' '\n' | grep -E '^surface:[0-9]+$' | head -n1 || true)"
            SEND_ARGS=(send --workspace "$WORKSPACE")
            KEY_ARGS=(send-key --workspace "$WORKSPACE")
            if [ -n "$SURFACE_REF" ]; then
                SEND_ARGS+=(--surface "$SURFACE_REF")
                KEY_ARGS+=(--surface "$SURFACE_REF")
            fi
            SEND_ARGS+=("$CMD")
            KEY_ARGS+=(Return)
            if ! "$CMUX_BIN" "${SEND_ARGS[@]}" >/dev/null 2>&1; then
                printf 'paperflow-continue: cmux send failed\n' >&2
                cmux_fallback_cascade
            elif ! "$CMUX_BIN" "${KEY_ARGS[@]}" >/dev/null 2>&1; then
                printf 'paperflow-continue: cmux send-key failed\n' >&2
                cmux_fallback_cascade
            else
                printf 'paperflow-continue: opened new cmux surface in workspace %s for slug %s\n' "$WORKSPACE" "$SLUG"
                exit 0
            fi
        fi
        # Fall through to whichever PATH_TAKEN cmux_fallback_cascade picked.
        ;;
esac

case "$PATH_TAKEN" in
    tmux)
        tmux new-window -n "claude:${SLUG}" "$CMD"
        ;;
    iterm)
        AS_CMD="$(osascript_escape "$CMD")"
        /usr/bin/osascript <<EOF
tell application "iTerm"
    activate
    tell current window
        create tab with default profile
        tell current session
            write text "${AS_CMD}"
        end tell
    end tell
end tell
EOF
        ;;
    apple_terminal)
        AS_CMD="$(osascript_escape "$CMD")"
        /usr/bin/osascript <<EOF
tell application "Terminal"
    activate
    do script "${AS_CMD}"
end tell
EOF
        ;;
    fallback_apple_terminal)
        AS_CMD="$(osascript_escape "$CMD")"
        /usr/bin/osascript <<EOF
tell application "Terminal"
    activate
    do script "${AS_CMD}"
end tell
EOF
        ;;
esac

printf 'paperflow-continue: opened new tab via %s for slug %s\n' "$PATH_TAKEN" "$SLUG"
