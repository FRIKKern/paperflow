#!/usr/bin/env bash
# paperflow-doctor — health & integrity check for the paperflow installation.
# Modes:  --fast (default; cache-aware, may re-exec --full once if cache stale)
#         --full (run every check, write cache at ~/.paperflow/doctor.cache.json)
#         --ensure-bd (targeted: bd init the nearest git-repo root if not done)
#         --bindings (audit doc HTMLs against live bridge registrations; JSON only)
# Exit:   0 ok  · 1 warnings  · 2 critical (or paperflow-preflight reported failure)
# Cache TTL: 86400s. macOS-portable bash 3.2; jq required, no node/python.
# Auto-fixes hook scripts, helper bins, and renderers when sources are present.
# Output: single JSON object on stdout.

set -u

REPO="__REPO__"
NODE_BIN="__NODE_BIN__"

CACHE_DIR="$HOME/.paperflow"
CACHE_FILE="$CACHE_DIR/doctor.cache.json"
CACHE_TTL=86400
MODE="--fast"
CHECKS_RUN=0
CHECKS_PASSED=0
ISSUES_JSONL=""
AUTOFIXED_JSONL=""
WORST=0  # 0 ok · 1 warn · 2 critical

# Per-instance-bridge constants (Q11 of 2026-05-11-bridge-binding-contract).
INSTANCES_DIR="$HOME/.paperflow/instances"
HEARTBEAT_FRESH_S=10   # ≤ 10 s of slack on the last heartbeat/registration
TCP_PROBE_TIMEOUT_S=1  # bash's /dev/tcp redirect blocks; cap with `nc` -w when available
REAP_AGE_S=300         # ≥ 5 min mtime + dead PID → reap orphan JSONL (under --repair)
DOCS_ROOT="$HOME/docs/paperflow"
REAP_ENABLED=0         # set to 1 when --repair is passed (Q11/Q12 reap-on-repair)
# Seed REAPED_JSONL from the pre-exec env var (paths reaped before the
# fast→full re-exec carry across). Newline-delimited list of reaped paths.
REAPED_JSONL="${PAPERFLOW_DOCTOR_REAPED:-}"

# Args: one mode flag + optional --repair (instance-check reaps under --repair).
# --repair only affects the instance-check pass; other auto-fixes (hooks/bins/
# renderers) already run unconditionally because they're side-effect-free.
MODE_SEEN=0
for arg in "$@"; do
    case "$arg" in
        ""|"--fast")   MODE="--fast";   MODE_SEEN=1 ;;
        "--full")      MODE="--full";   MODE_SEEN=1 ;;
        "--ensure-bd") MODE="--ensure-bd"; MODE_SEEN=1 ;;
        "--bindings")  MODE="--bindings";  MODE_SEEN=1 ;;
        "--repair")    REAP_ENABLED=1 ;;
        *) printf 'usage: paperflow-doctor [--fast | --full | --ensure-bd | --bindings] [--repair]\n' >&2; exit 1 ;;
    esac
done
# default mode when only --repair was passed
[ "$MODE_SEEN" = "0" ] && MODE="--fast"

# ── --ensure-bd: targeted Beads init for the current repo ──────────
# Folded in from the legacy `paperflow-bd-init` binary (Cut 2, 2026-05).
# Walks up to the nearest git repo root, runs `bd init` if .beads/ is
# missing, exits 0 on success / already-init. JSON on stdout, exit 2 on
# failure. Skips the rest of doctor's checks.
if [ "$MODE" = "--ensure-bd" ]; then
    if ! command -v bd >/dev/null 2>&1; then
        jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '{ok:false, action:"missing_dep", db_path:"", error:"bd not on PATH (brew install beads)", ts:$ts}'
        exit 2
    fi
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    if [ -d "$REPO_ROOT/.beads" ]; then
        jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg path "$REPO_ROOT/.beads" \
            '{ok:true, action:"already_init", db_path:$path, ts:$ts}'
        exit 0
    fi
    if ( cd "$REPO_ROOT" && bd init >/dev/null 2>&1 ); then
        jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg path "$REPO_ROOT/.beads" \
            '{ok:true, action:"init", db_path:$path, ts:$ts}'
        exit 0
    fi
    jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg root "$REPO_ROOT" \
        '{ok:false, action:"init_failed", db_path:"", error:"bd init failed at \($root)", ts:$ts}'
    exit 2
fi

# (--bindings subcommand handler is defined below, after helpers, because it
# reuses extract_doc_target + tcp_listening + iso_age_seconds.)

# ── helpers ────────────────────────────────────────────────────────
now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ; }

now_epoch() { date +%s 2>/dev/null || echo 0; }

# pid_alive PID  → 0 if alive, non-zero otherwise.  `kill -0` works for any
# process whose owner you can signal; macOS returns ESRCH only for truly-gone PIDs.
pid_alive() {
    [ -n "${1:-}" ] || return 1
    case "$1" in *[!0-9]*) return 1 ;; esac
    kill -0 "$1" 2>/dev/null
}

# tcp_listening PORT  → 0 if something is accepting on localhost:PORT.
# Prefer `nc -z -w<TIMEOUT>` (POSIX-ish, ships with macOS); fall back to /dev/tcp.
tcp_listening() {
    local port="$1"
    case "$port" in ""|*[!0-9]*) return 1 ;; esac
    if command -v nc >/dev/null 2>&1; then
        nc -z -w "$TCP_PROBE_TIMEOUT_S" 127.0.0.1 "$port" >/dev/null 2>&1
        return $?
    fi
    # bash builtin TCP — no timeout, but only used as last resort.
    ( exec 3<>"/dev/tcp/127.0.0.1/$port" ) >/dev/null 2>&1
}

# instance_last_signal_ts JSONL_PATH  → ISO timestamp of latest heartbeat or
# registration line, or empty when none recorded yet. We accept both because
# a fresh daemon may not have emitted its first heartbeat (3 s cadence) but
# has already accepted at least one registration.
instance_last_signal_ts() {
    local path="$1"
    [ -f "$path" ] || return 1
    # tac substitute: print lines in reverse using awk so the freshest signal wins.
    awk '/"type":"heartbeat"/ || /"type":"registration"/' "$path" 2>/dev/null \
        | tail -1 \
        | jq -r '(.registered_at // .ts) // empty' 2>/dev/null
}

# iso_age_seconds ISO_TIMESTAMP  → integer seconds since that ISO ts, or empty
# when input is empty/unparseable. Uses `date -j -f` (BSD) which is what ships
# on macOS; we deliberately do NOT depend on GNU coreutils.
iso_age_seconds() {
    local iso="$1"
    [ -n "$iso" ] || return 1
    # strip fractional seconds + trailing Z so BSD date can parse.
    local stripped
    stripped="$(printf '%s' "$iso" | sed 's/\..*Z$//; s/Z$//')"
    local epoch
    epoch="$(date -j -u -f '%Y-%m-%dT%H:%M:%S' "$stripped" +%s 2>/dev/null)" || return 1
    [ -n "$epoch" ] || return 1
    echo $(( $(now_epoch) - epoch ))
}

# file_age_seconds PATH  → integer seconds since file mtime, or empty when
# the file is missing. macOS BSD stat (`-f %m`) — no GNU dependency.
file_age_seconds() {
    local path="$1" mt now
    [ -f "$path" ] || return 1
    mt="$(stat -f %m "$path" 2>/dev/null)" || return 1
    [ -n "$mt" ] || return 1
    now="$(now_epoch)"
    echo $(( now - mt ))
}

# cmux_surface_alive WORKSPACE_REF SURFACE_REF  → 0 if the surface still
# exists in the named cmux workspace; 1 otherwise. Returns 0 (alive) and
# emits a side-channel signal "cmux:unavailable" via global CMUX_AVAILABLE=0
# when cmux is not on PATH, so callers can treat it as "skip this leg".
# The triple-check spec (Q11): PID + (cmux-surface OR cmux-unavailable) +
# heartbeat. Implementation greps `cmux list-pane-surfaces --workspace W`
# for the recorded surface ref — exit-status is unreliable across cmux
# versions, but the surface ref's literal presence is a stable signal.
CMUX_AVAILABLE=1
if ! command -v cmux >/dev/null 2>&1; then
    CMUX_AVAILABLE=0
fi
cmux_surface_alive() {
    local ws="$1" sf="$2"
    [ "$CMUX_AVAILABLE" = "1" ] || return 0     # gracefully skip the leg
    [ -n "$ws" ] && [ -n "$sf" ] || return 0    # no recorded refs → skip
    cmux list-pane-surfaces --workspace "$ws" 2>/dev/null | grep -qE "(^|[[:space:]])${sf}([[:space:]]|$)"
}

# extract_doc_target FILE  → JSON object {bridge_url,doc_nonce} for the
# window.CLAUDE_TARGET literal embedded in the doc, or {} when missing.
# Best-effort regex over the assignment up to the terminating semicolon —
# CLAUDE_TARGET is small (single object, ~10 fields), so a non-validating
# scan is good enough to surface state without pulling in a JS parser.
extract_doc_target() {
    local file="$1" url="" nonce=""
    [ -f "$file" ] || { printf '%s' '{}'; return 0; }
    # Slurp the assignment window. awk reads from `window.CLAUDE_TARGET = ` up
    # to the first `;` after it; that's the assignment statement we want.
    local blob
    blob="$(awk '
        /window\.CLAUDE_TARGET[[:space:]]*=/ { capturing=1 }
        capturing { buf = buf $0 "\n"; if (index($0, ";")) { print buf; exit } }
    ' "$file" 2>/dev/null)"
    [ -n "$blob" ] || { printf '%s' '{}'; return 0; }
    url="$(printf '%s' "$blob"   | grep -oE '"bridge_url"[[:space:]]*:[[:space:]]*"[^"]*"' \
                                  | head -1 | sed -E 's/.*"bridge_url"[^"]*"([^"]*)"/\1/')"
    nonce="$(printf '%s' "$blob" | grep -oE '"doc_nonce"[[:space:]]*:[[:space:]]*"[^"]*"' \
                                  | head -1 | sed -E 's/.*"doc_nonce"[^"]*"([^"]*)"/\1/')"
    jq -nc --arg u "$url" --arg n "$nonce" \
        '{bridge_url:(if $u=="" then null else $u end), doc_nonce:(if $n=="" then null else $n end)}'
}

bump_worst() {
    case "$1" in
        critical) [ "$WORST" -lt 2 ] && WORST=2 ;;
        warning)  [ "$WORST" -lt 1 ] && WORST=1 ;;
    esac; return 0
}

add_issue() {
    # add_issue id severity title repair_command auto_fix_safe(true|false)
    local line
    line="$(jq -nc --arg id "$1" --arg severity "$2" --arg title "$3" \
                  --arg repair_command "$4" --argjson auto_fix_safe "$5" \
        '{id:$id, severity:$severity, title:$title, repair_command:$repair_command, auto_fix_safe:$auto_fix_safe}')" || return 0
    ISSUES_JSONL="${ISSUES_JSONL}${line}
"
    bump_worst "$2"
}

add_autofixed() {
    local line
    line="$(jq -nc --arg id "$1" --arg note "$2" '{id:$id, note:$note}')" || return 0
    AUTOFIXED_JSONL="${AUTOFIXED_JSONL}${line}
"
}

# add_reaped PATH — record a reaped instance JSONL for the JSON output.
# Caller is responsible for the actual `rm`; this is bookkeeping only.
add_reaped() {
    REAPED_JSONL="${REAPED_JSONL}$1
"
}

pass() { CHECKS_RUN=$((CHECKS_RUN+1)); CHECKS_PASSED=$((CHECKS_PASSED+1)); }
fail() { CHECKS_RUN=$((CHECKS_RUN+1)); }

cache_is_fresh() {
    local mt now age
    [ -f "$CACHE_FILE" ] || return 1
    mt="$(stat -f %m "$CACHE_FILE" 2>/dev/null || echo 0)"
    [ "$mt" = "0" ] && return 1
    now="$(date +%s 2>/dev/null || echo 0)"
    age=$((now - mt))
    [ "$age" -lt "$CACHE_TTL" ]
}

emit_and_exit() {
    local ec=0
    [ "$WORST" = "2" ] && ec=2
    [ "$WORST" = "1" ] && ec=1
    local issues_arr autofixed_arr reaped_arr ok_val
    issues_arr="$(printf '%s' "$ISSUES_JSONL" | jq -cs '. // []' 2>/dev/null || printf '[]')"
    autofixed_arr="$(printf '%s' "$AUTOFIXED_JSONL" | jq -cs '. // []' 2>/dev/null || printf '[]')"
    reaped_arr="$(printf '%s' "$REAPED_JSONL" | awk 'NF{printf "%s\n",$0}' \
                  | jq -R . | jq -cs '. // []' 2>/dev/null || printf '[]')"
    [ "$ec" = "0" ] && ok_val=true || ok_val=false
    jq -nc --argjson ok "$ok_val" --argjson exit_code "$ec" --arg ts "$(now_iso)" \
           --argjson checks_run "$CHECKS_RUN" --argjson checks_passed "$CHECKS_PASSED" \
           --argjson auto_fixed "$autofixed_arr" --argjson issues "$issues_arr" \
           --argjson reaped "$reaped_arr" \
           --argjson i_total "${INSTANCES_TOTAL:-0}" --argjson i_live "${INSTANCES_LIVE:-0}" \
           --argjson i_orphan "${INSTANCES_ORPHAN:-0}" --argjson i_stuck "${INSTANCES_STUCK:-0}" \
           --argjson i_late "${INSTANCES_LATE:-0}" --argjson i_surface_dead "${INSTANCES_SURFACE_DEAD:-0}" \
        '{ok:$ok, exit:$exit_code, ts:$ts, checks_run:$checks_run, checks_passed:$checks_passed,
          auto_fixed:$auto_fixed, issues:$issues, reaped:$reaped,
          instance_check:{total:$i_total, live:$i_live, orphan:$i_orphan,
                          daemon_stuck:$i_stuck, heartbeat_late:$i_late,
                          surface_dead:$i_surface_dead}}'
    exit "$ec"
}

# ── --bindings: audit doc HTMLs against live bridge registrations ──
# Distinct from the standard sweep. Used by paperflow-4t5 (migration) to know
# which docs still reference defunct bridges. Returns JSON; exits 0 always.
if [ "$MODE" = "--bindings" ]; then
    # 1. Walk every live instance JSONL, build the set of registered (port,nonce).
    #    LIVE_PAIRS is a newline-delimited table: "<port>\t<nonce>".
    LIVE_PAIRS=""
    LIVE_PORTS=" "
    if [ -d "$INSTANCES_DIR" ]; then
        for f in "$INSTANCES_DIR"/*.jsonl; do
            [ -f "$f" ] || continue
            # First line is the session record — extract port + owner_pid.
            port="$(head -1 "$f" 2>/dev/null | jq -r '.port // empty' 2>/dev/null)"
            owner_pid="$(head -1 "$f" 2>/dev/null | jq -r '.owner_pid // empty' 2>/dev/null)"
            [ -n "$port" ] || continue
            # Aliveness = owner alive + port listening. Skip dead daemons; their
            # nonces are no longer queryable, so any doc bound to them is orphaned.
            pid_alive "$owner_pid" || continue
            tcp_listening "$port"  || continue
            LIVE_PORTS="${LIVE_PORTS}${port} "
            # Every registration line in this JSONL is currently mapped (the
            # in-memory registry rebuilds from the file on restart per G3).
            while IFS= read -r nonce; do
                [ -n "$nonce" ] || continue
                LIVE_PAIRS="${LIVE_PAIRS}${port}	${nonce}
"
            done < <(grep '"type":"registration"' "$f" 2>/dev/null \
                       | jq -r '.doc_nonce // empty' 2>/dev/null)
        done
    fi

    # 2. Walk every doc HTML; categorise each.
    DOCS_JSONL=""
    BOUND_LIVE=0; BOUND_ORPHANED=0; UNBOUND_STALE=0
    DOC_DIRS="goals plans specs grills questionnaires notes changelog audits"
    for dir in $DOC_DIRS; do
        [ -d "$DOCS_ROOT/$dir" ] || continue
        while IFS= read -r doc; do
            [ -f "$doc" ] || continue
            target="$(extract_doc_target "$doc")"
            url="$(printf   '%s' "$target" | jq -r '.bridge_url // empty' 2>/dev/null)"
            nonce="$(printf '%s' "$target" | jq -r '.doc_nonce  // empty' 2>/dev/null)"
            state=""; port=""
            if [ -z "$url" ]; then
                # Legacy doc (cmux_surface-only, or no target at all).
                state="unbound-stale"; UNBOUND_STALE=$((UNBOUND_STALE+1))
            else
                # Strip "http(s)://host:" prefix and any path suffix → port.
                port="$(printf '%s' "$url" | sed -E 's@^[a-z]+://[^:/]*:?@@; s@/.*$@@')"
                if [ -n "$port" ] && [ -n "$nonce" ] \
                   && printf '%s' "$LIVE_PAIRS" | grep -qF "$(printf '%s\t%s' "$port" "$nonce")"; then
                    state="bound-live"; BOUND_LIVE=$((BOUND_LIVE+1))
                elif [ -n "$port" ] && [ "${LIVE_PORTS#* $port }" != "$LIVE_PORTS" ]; then
                    # Port has a live daemon, but the nonce is not in its registry
                    # (e.g. daemon restarted and lost the in-memory registration).
                    state="unbound-stale"; UNBOUND_STALE=$((UNBOUND_STALE+1))
                else
                    state="bound-orphaned"; BOUND_ORPHANED=$((BOUND_ORPHANED+1))
                fi
            fi
            doc_line="$(jq -nc --arg p "$doc" --arg s "$state" \
                              --arg u "${url:-}" --arg n "${nonce:-}" --arg port "${port:-}" \
                '{path:$p, state:$s, bridge_url:(if $u=="" then null else $u end),
                  doc_nonce:(if $n=="" then null else $n end),
                  port:(if $port=="" then null else ($port|tonumber? // null) end)}')"
            DOCS_JSONL="${DOCS_JSONL}${doc_line}
"
        done < <(find "$DOCS_ROOT/$dir" -maxdepth 4 -name '*.html' -type f 2>/dev/null)
    done

    docs_arr="$(printf '%s' "$DOCS_JSONL" | jq -cs '. // []' 2>/dev/null || printf '[]')"
    jq -nc --argjson docs "$docs_arr" \
           --argjson bl "$BOUND_LIVE" --argjson bo "$BOUND_ORPHANED" --argjson us "$UNBOUND_STALE" \
           --arg ts "$(now_iso)" \
        '{ok:true, ts:$ts, docs:$docs,
          summary:{bound_live:$bl, bound_orphaned:$bo, unbound_stale:$us}}'
    exit 0
fi

# ── 0. paperflow-preflight gate ────────────────────────────────────
# Services down beats config drift — propagate preflight JSON unchanged.
if [ -x "$HOME/.local/bin/paperflow-preflight" ]; then
    PF_OUT="$("$HOME/.local/bin/paperflow-preflight" 2>/dev/null)"
    PF_EXIT=$?
    if [ "$PF_EXIT" != "0" ] && [ -n "$PF_OUT" ]; then
        printf '%s\n' "$PF_OUT"
        exit 2
    fi
    pass
fi

# ── 0b. paperflow-daemon /health probe ─────────────────────────────
# Three legs (Goal paperflow-du4 contract):
#   1. HEAD /health → 200 (cheap existence probe)
#   2. GET  /health → 200 + body parses as JSON
#   3. body.ok === true; surface body.version as informational
# Each leg counts as one check; collective failure is critical because
# downstream skills depend on the daemon for doc-button routing.
DAEMON_URL="${PAPERFLOW_DAEMON_URL:-http://127.0.0.1:8767}"
LP="${LABEL_PREFIX:-dev.$USER}"

# Supervisor decision — drives repair_command for daemon:health_* issues.
# Spec: ~/docs/paperflow/specs/2026-05-17-daemon-supervisor-contract.html §3.
# Order: (1) live cmux workspace named paperflow-daemon, (2) loaded launchd
# plist, (3) none. The detection is *probe-only* — we don't mutate anything.
DAEMON_SUPERVISOR="none"
if command -v cmux >/dev/null 2>&1 \
   && cmux list-workspaces 2>/dev/null \
        | awk '{ l=$0; sub(/^[* ]+/,"",l); sub(/^[^ \t]+[ \t]+/,"",l);
                 sub(/[ \t]+\[selected\][ \t]*$/,"",l); sub(/[ \t]+$/,"",l);
                 print l }' \
        | grep -qx 'paperflow-daemon'; then
    DAEMON_SUPERVISOR="cmux"
elif launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "${LP}.paperflow-daemon"; then
    DAEMON_SUPERVISOR="launchd"
fi
case "$DAEMON_SUPERVISOR" in
    cmux)    DAEMON_REPAIR="$HOME/.local/bin/paperflow-daemon-spawn --force-cmux" ;;
    launchd) DAEMON_REPAIR="launchctl kickstart -k gui/$(id -u)/${LP}.paperflow-daemon" ;;
    *)       DAEMON_REPAIR="$HOME/.local/bin/paperflow-daemon-spawn   # auto-picks supervisor" ;;
esac
add_autofixed "daemon:supervisor" "paperflow-daemon supervisor: $DAEMON_SUPERVISOR"

DAEMON_HEALTH_HEAD_CODE="$(curl -sS --max-time 2 -o /dev/null -w '%{http_code}' \
    -I "$DAEMON_URL/health" 2>/dev/null || echo 000)"
if [ "$DAEMON_HEALTH_HEAD_CODE" = "200" ]; then
    pass
else
    fail; add_issue "daemon:health_head_failed" "critical" \
                    "HEAD $DAEMON_URL/health returned $DAEMON_HEALTH_HEAD_CODE (expected 200)" \
                    "$DAEMON_REPAIR" false
fi

DAEMON_HEALTH_BODY="$(curl -sS --max-time 2 "$DAEMON_URL/health" 2>/dev/null || true)"
if [ -n "$DAEMON_HEALTH_BODY" ] && printf '%s' "$DAEMON_HEALTH_BODY" | jq -e '.ok == true' >/dev/null 2>&1; then
    pass
    DAEMON_VERSION="$(printf '%s' "$DAEMON_HEALTH_BODY" | jq -r '.version // empty' 2>/dev/null)"
    # Informational only — surface version as a non-failing autofix-style note.
    [ -n "$DAEMON_VERSION" ] && add_autofixed "daemon:version" "paperflow-daemon version $DAEMON_VERSION"
else
    fail; add_issue "daemon:health_body_bad" "critical" \
                    "GET $DAEMON_URL/health did not return a JSON body with ok:true" \
                    "$DAEMON_REPAIR" false
fi

# ── 1. dependency presence ─────────────────────────────────────────
# dep:title:repair triplets (curl repair has no `brew` because it ships with macOS).
for triple in \
    "bd:Beads CLI is not installed:brew install beads" \
    "node:Node is not installed:brew install node" \
    "jq:jq is not installed:brew install jq" \
    "curl:curl is not installed:# install curl via your OS package manager"
do
    dep="${triple%%:*}"; rest="${triple#*:}"; title="${rest%%:*}"; repair="${rest#*:}"
    if command -v "$dep" >/dev/null 2>&1; then pass
    else fail; add_issue "missing_dep:$dep" "critical" "$title" "$repair" false
    fi
done

# ── 2. settings integrity ──────────────────────────────────────────
SETTINGS="$HOME/.claude/settings.json"
if [ ! -f "$SETTINGS" ]; then
    fail; add_issue "settings:missing" "critical" "~/.claude/settings.json is missing" "bash $REPO/install.sh" false
elif jq empty "$SETTINGS" >/dev/null 2>&1; then pass
else fail; add_issue "settings:invalid_json" "critical" \
                     "~/.claude/settings.json is not valid JSON" \
                     "bash $REPO/install.sh   # restores from a fresh render" false
fi

# ── 3. hook scripts (auto-fix safe) ────────────────────────────────
for hook in inject-principles.sh auto-open-doc.sh validate-paperflow-doc.sh event-on-save.sh; do
    DST="$HOME/.claude/hooks/$hook"
    SRC="$REPO/hooks/$hook"
    if [ -x "$DST" ]; then pass; continue; fi
    if [ -f "$SRC" ]; then
        mkdir -p "$HOME/.claude/hooks" 2>/dev/null
        if cp "$SRC" "$DST" 2>/dev/null && chmod +x "$DST" 2>/dev/null; then
            add_autofixed "hook:$hook" "copied from $SRC"; pass; continue
        fi
    fi
    fail; add_issue "hook:missing:$hook" "warning" \
                    "Hook script $hook is missing and could not be auto-restored" \
                    "bash $REPO/install.sh" true
done

# ── 4. helper binaries (auto-fix safe) ─────────────────────────────
# bin-name|source-basename pairs (paperflow-target uses get-terminal-target.sh).
# paperflow-daemon is the real binary that consolidated aux + bridge (Goal
# paperflow-du4); paperflow-aux-daemon + claude-bridge.js are kept as
# backwards-compat shims for one release.
for pair in \
    paperflow-validate:paperflow-validate \
    paperflow-target:get-terminal-target.sh \
    paperflow-continue:paperflow-continue \
    paperflow-preflight:paperflow-preflight \
    paperflow-daemon:paperflow-daemon \
    paperflow-aux-daemon:paperflow-aux-daemon \
    claude-bridge.js:claude-bridge.js \
    paperflow-migrate-legacy-goals:paperflow-migrate-legacy-goals
do
    bin="${pair%%:*}"; src_name="${pair#*:}"
    DST="$HOME/.local/bin/$bin"
    SRC="$REPO/bin/$src_name"
    if [ -x "$DST" ]; then pass; continue; fi
    if [ -f "$SRC" ]; then
        mkdir -p "$HOME/.local/bin" 2>/dev/null
        copied=0
        if [ "$bin" = "paperflow-preflight" ]; then
            sed -e "s|__NODE_BIN__|$NODE_BIN|g" \
                -e "s|__BRIDGE_JS__|$REPO/bin/claude-bridge.js|g" \
                "$SRC" > "$DST" 2>/dev/null && chmod +x "$DST" 2>/dev/null && copied=1
        else
            cp "$SRC" "$DST" 2>/dev/null && chmod +x "$DST" 2>/dev/null && copied=1
        fi
        if [ "$copied" = "1" ]; then
            add_autofixed "bin:$bin" "copied from $SRC"; pass; continue
        fi
    fi
    fail; add_issue "bin:missing:$bin" "warning" \
                    "Helper binary $bin is missing and could not be auto-restored" \
                    "bash $REPO/install.sh" true
done

# ── 5. renderers (auto-fix safe) ───────────────────────────────────
for asset in doc.css doc.js grill.css grill.js mermaid-zoom.css mermaid-zoom.js \
             live-render.css live-render.js goal-path-rail.css goal-path-rail.js \
             diff-modal.js text-diff.js simplify-button.js; do
    DST="$HOME/docs/paperflow/_lib/$asset"
    SRC="$REPO/lib/$asset"
    if [ -f "$DST" ]; then pass; continue; fi
    if [ -f "$SRC" ]; then
        mkdir -p "$HOME/docs/paperflow/_lib" 2>/dev/null
        if cp "$SRC" "$DST" 2>/dev/null; then
            add_autofixed "renderer:$asset" "copied from $SRC"; pass; continue
        fi
    fi
    fail; add_issue "renderer:missing:$asset" "warning" \
                    "Renderer asset $asset is missing and could not be auto-restored" \
                    "bash $REPO/install.sh" true
done

# ── 6. session sidecars — staleness sweep ──────────────────────────
# The per-instance bridge JSONLs are gone (Goal paperflow-du4). The daemon
# now lives at :8767 and persists state in registry.jsonl; what remains
# under ~/.paperflow/instances/ are tiny *.session sidecars written by
# paperflow-session-register (one line, the session_id). These are
# pragmatic discovery files for helpers that don't have CLAUDE_SESSION_ID
# in their env.
#
# Doctor's job here: any sidecar older than SIDECAR_STALE_S is stale (the
# Claude Code session it described almost certainly ended without firing
# SessionEnd → unregister). Offer to remove under --repair.
SIDECAR_STALE_S=86400   # 24 h — task spec
INSTANCES_LIVE=0
INSTANCES_ORPHAN=0
INSTANCES_STUCK=0
INSTANCES_LATE=0
INSTANCES_TOTAL=0
INSTANCES_SURFACE_DEAD=0
SIDECAR_STALE_COUNT=0
if [ -d "$INSTANCES_DIR" ]; then
    for f in "$INSTANCES_DIR"/*.session; do
        [ -f "$f" ] || continue
        INSTANCES_TOTAL=$((INSTANCES_TOTAL+1))
        SID="$(basename "$f" .session)"
        F_AGE="$(file_age_seconds "$f" 2>/dev/null || echo 0)"
        if [ "${F_AGE:-0}" -ge "$SIDECAR_STALE_S" ] 2>/dev/null; then
            if [ "$REAP_ENABLED" = "1" ]; then
                rm -f "$f" 2>/dev/null && add_reaped "$f"
                continue
            fi
            SIDECAR_STALE_COUNT=$((SIDECAR_STALE_COUNT+1))
            add_issue "sidecar:stale:$SID" "warning" \
                      "Session sidecar $f is older than ${SIDECAR_STALE_S}s (likely no SessionEnd fired)" \
                      "rm $f   # safe to remove; daemon registry is authoritative" true
            continue
        fi
        INSTANCES_LIVE=$((INSTANCES_LIVE+1))
    done
fi
# Sidecar check counts as ONE logical check regardless of file count.
if [ "$SIDECAR_STALE_COUNT" = "0" ]; then
    pass
else
    fail
fi

# ── 6b. registry.jsonl integrity ───────────────────────────────────
# The consolidated daemon's source of truth on restart. Verify it exists
# (when the daemon has ever started), is readable, parses as line-delimited
# JSON, and is ≤ 10 MB. Compaction is the daemon's job at boot; doctor
# just flags when it hasn't happened.
REGISTRY_FILE="$HOME/.paperflow/registry.jsonl"
REGISTRY_MAX_BYTES=$((10 * 1024 * 1024))   # 10 MB
if [ -f "$REGISTRY_FILE" ]; then
    if [ ! -r "$REGISTRY_FILE" ]; then
        fail; add_issue "registry:unreadable" "warning" \
                        "$REGISTRY_FILE exists but is not readable" \
                        "chmod 644 $REGISTRY_FILE" false
    else
        REG_SIZE="$(stat -f %z "$REGISTRY_FILE" 2>/dev/null || echo 0)"
        # Parse check: every non-empty line must be valid JSON. jq -e
        # on a stream returns 0 only when every line parsed.
        if ! jq -e '.' "$REGISTRY_FILE" >/dev/null 2>&1; then
            fail; add_issue "registry:malformed" "warning" \
                            "$REGISTRY_FILE contains lines that are not valid JSON" \
                            "# inspect with: tail $REGISTRY_FILE | jq ." false
        elif [ "${REG_SIZE:-0}" -gt "$REGISTRY_MAX_BYTES" ] 2>/dev/null; then
            fail; add_issue "registry:oversize" "warning" \
                            "$REGISTRY_FILE is ${REG_SIZE} bytes (> ${REGISTRY_MAX_BYTES}) — daemon should compact at boot" \
                            "launchctl kickstart -k gui/$(id -u)/${LABEL_PREFIX:-dev.$USER}.paperflow-daemon" false
        else
            pass
        fi
    fi
else
    # File missing is benign — daemon writes it lazily. Pass.
    pass
fi

# ── 6c. plist alignment: paperflow-daemon plist present; old labels not ─
# Replaces the F4-era check that looked for aux + claude-bridge agents.
# Under the supervisor-contract (2026-05-17), cmux hosts ship the daemon
# plist in a DORMANT state (RunAtLoad=false, KeepAlive=false) — present on
# disk as a safety-net, not loaded into launchctl. So the check is "plist
# file exists on disk"; whether it's the active supervisor or the dormant
# safety-net is reported via the daemon:supervisor autofixed note above.
DAEMON_LBL="${LP}.paperflow-daemon"
DAEMON_PLIST="$HOME/Library/LaunchAgents/${DAEMON_LBL}.plist"
if [ -f "$DAEMON_PLIST" ]; then
    pass
else
    fail; add_issue "launchagent:paperflow-daemon_missing" "critical" \
                    "paperflow-daemon LaunchAgent plist ($DAEMON_PLIST) is not on disk" \
                    "bash $REPO/install.sh" false
fi

# Legacy labels — bootout if still loaded.
for legacy in "${LP}.paperflow-aux" "${LP}.claude-bridge"; do
    if launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "$legacy"; then
        fail; add_issue "launchagent:legacy_loaded:$legacy" "warning" \
                        "Legacy LaunchAgent $legacy is still loaded — superseded by paperflow-daemon" \
                        "launchctl bootout gui/$(id -u)/$legacy" false
    else
        pass
    fi
done

# ── 7. fast-mode gate: merge cache or re-exec ──────────────────────
if [ "$MODE" = "--fast" ]; then
    if cache_is_fresh; then
        # merge cached issues by id (fresh wins; cache only fills new ids)
        CURRENT_IDS=" $(printf '%s' "$ISSUES_JSONL" | jq -r '.id' 2>/dev/null | tr '\n' ' ') "
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            cid="$(printf '%s' "$line" | jq -r '.id' 2>/dev/null)"
            case "$CURRENT_IDS" in
                *" $cid "*) ;;
                *)
                    csev="$(printf '%s' "$line" | jq -r '.severity' 2>/dev/null)"
                    ISSUES_JSONL="${ISSUES_JSONL}${line}
"
                    bump_worst "$csev"
                    ;;
            esac
        done <<EOF
$(jq -c '.issues[]?' "$CACHE_FILE" 2>/dev/null)
EOF
        emit_and_exit
    elif [ "${PAPERFLOW_DOCTOR_REENTERED:-0}" != "1" ]; then
        export PAPERFLOW_DOCTOR_REENTERED=1
        # Hand off the reaped-path list to the --full re-exec so it shows up
        # in the final JSON. (The re-exec sweep won't see the reaped files
        # because they're already gone.) Preserve --repair as well.
        export PAPERFLOW_DOCTOR_REAPED="$REAPED_JSONL"
        if [ "$REAP_ENABLED" = "1" ]; then
            exec "$0" --full --repair
        else
            exec "$0" --full
        fi
    else
        MODE="--full"   # re-entry guard fired; keep going in-place
    fi
fi

# ─── FULL CHECKS ───────────────────────────────────────────────────

# F1. tool versions
if command -v bd >/dev/null 2>&1; then
    BD_VER="$(bd --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)"
    if [ -n "$BD_VER" ]; then
        BD_MAJ="$(printf '%s' "$BD_VER" | cut -d. -f1)"
        BD_MIN="$(printf '%s' "$BD_VER" | cut -d. -f2)"
        if [ "${BD_MAJ:-0}" -lt 1 ] && [ "${BD_MIN:-0}" -lt 4 ] 2>/dev/null; then
            fail; add_issue "version:bd_old" "warning" \
                            "Beads CLI is older than 0.4.0 (found $BD_VER)" \
                            "brew upgrade beads" false
        else pass
        fi
    fi
fi

if command -v node >/dev/null 2>&1; then
    NODE_MAJ="$(node -v 2>/dev/null | tr -d v | cut -d. -f1)"
    if [ -n "$NODE_MAJ" ] && [ "$NODE_MAJ" -lt 22 ] 2>/dev/null; then
        fail; add_issue "version:node_old" "critical" \
                        "Node major version is < 22 (found $NODE_MAJ)" \
                        "brew install node   # or: nvm install 22 && nvm use 22" false
    else pass
    fi
fi

# F2. npm globals (unlighthouse is info-only — site-audit is opt-in)
NPM_ROOT="$(npm root -g 2>/dev/null || true)"
if [ -n "$NPM_ROOT" ] && [ -d "$NPM_ROOT" ]; then
    if [ -d "$NPM_ROOT/mermaid" ]; then pass
    else fail; add_issue "npm:mermaid_missing" "warning" "Global npm package 'mermaid' not found" "npm install -g mermaid" false
    fi
    pass
    [ -d "$NPM_ROOT/@unlighthouse" ] || add_issue "npm:unlighthouse_missing" "info" \
        "Global '@unlighthouse' not found (only needed for site-audit)" \
        "npm install -g @unlighthouse/cli puppeteer" false
fi

# F3. git outdated (skip silently if no upstream / network fail)
if [ -d "$REPO/.git" ] && git -C "$REPO" rev-parse '@{u}' >/dev/null 2>&1; then
    FETCH_OK=0
    if command -v timeout >/dev/null 2>&1; then
        timeout 5 git -C "$REPO" fetch --quiet >/dev/null 2>&1 && FETCH_OK=1
    else
        git -C "$REPO" fetch --quiet >/dev/null 2>&1 && FETCH_OK=1
    fi
    if [ "$FETCH_OK" = "1" ]; then
        BEHIND="$(git -C "$REPO" rev-list HEAD..@{u} --count 2>/dev/null || echo 0)"
        if [ "${BEHIND:-0}" -gt 0 ] 2>/dev/null; then
            fail; add_issue "git:outdated" "warning" \
                            "paperflow checkout is $BEHIND commit(s) behind upstream" \
                            "cd $REPO && git pull && bash install.sh" false
        else pass
        fi
    else pass
    fi
fi

# F4. LaunchAgent plist health (bridge skipped — under cmux it's a workspace, not an agent)
LR_LABEL="$(launchctl list 2>/dev/null | awk '/\.docs-livereload$/ {print $3; exit}')"
if [ -n "$LR_LABEL" ]; then
    UID_NUM="$(id -u)"
    if launchctl print "gui/$UID_NUM/$LR_LABEL" >/dev/null 2>&1; then pass
    else fail; add_issue "launchagent:docs-livereload_unhealthy" "warning" \
                         "docs-livereload LaunchAgent ($LR_LABEL) reports unhealthy" \
                         "launchctl kickstart -k gui/$UID_NUM/$LR_LABEL" false
    fi
fi

# F5. dock socket
if [ -S "$HOME/.paperflow/dock.sock" ]; then pass
else fail; add_issue "dock:socket_missing" "warning" \
                     "Dock socket ~/.paperflow/dock.sock not present" \
                     "bash $REPO/install.sh" false
fi

# F6. skill cap (CI-mirror — kept in sync with scripts/check-skill-count.sh)
SKILLS_CAP=8
if [ -d "$REPO/skills" ]; then
    SKILL_COUNT="$(find "$REPO/skills" -maxdepth 2 -name SKILL.md 2>/dev/null | wc -l | tr -d ' ')"
    if [ "${SKILL_COUNT:-0}" -gt "$SKILLS_CAP" ] 2>/dev/null; then
        fail; add_issue "skills:cap_exceeded" "warning" \
                        "Skill cap exceeded — paperflow's CI gate enforces <= $SKILLS_CAP (found $SKILL_COUNT)" \
                        "# remove or merge skills under $REPO/skills" false
    else pass
    fi
fi

# F6b. pointer-drift: per-repo vs per-scope active-goal can legitimately
# differ (this repo's last Goal vs this cmux/Claude session's last Goal).
# Surface as a non-fatal warning when both exist and disagree. No auto-fix
# — silently picking one can hide real bugs.
check_pointer_drift() {
    local repo_root repo_val scope_val
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
    [ -n "$repo_root" ] || return 0
    [ -r "$repo_root/.paperflow/active-goal" ] || return 0
    repo_val="$(head -n1 "$repo_root/.paperflow/active-goal" 2>/dev/null | tr -d '[:space:]')"
    [ -n "$repo_val" ] || return 0
    if command -v paperflow-active-scope >/dev/null 2>&1; then
        scope_val="$(paperflow-active-scope --read goal 2>/dev/null | tr -d '[:space:]')"
    elif [ -x "$HOME/.local/bin/paperflow-active-scope" ]; then
        scope_val="$("$HOME/.local/bin/paperflow-active-scope" --read goal 2>/dev/null | tr -d '[:space:]')"
    else
        return 0
    fi
    [ -n "$scope_val" ] || return 0
    if [ "$repo_val" != "$scope_val" ]; then
        fail; add_issue "pointer-drift" "warning" \
            "Per-repo pointer (${repo_val}) and per-scope pointer (${scope_val}) disagree — these can legitimately differ if you've worked across repos in this session. Run paperflow-active-scope --write goal ${repo_val} to align if intended." \
            "paperflow-active-scope --write goal ${repo_val}" false
    else
        pass
    fi
}
check_pointer_drift

# F7. write cache
mkdir -p "$CACHE_DIR" 2>/dev/null
{
    issues_arr_w="$(printf '%s' "$ISSUES_JSONL" | jq -cs '. // []' 2>/dev/null || printf '[]')"
    autofixed_arr_w="$(printf '%s' "$AUTOFIXED_JSONL" | jq -cs '. // []' 2>/dev/null || printf '[]')"
    jq -n --arg ts "$(now_iso)" --argjson issues "$issues_arr_w" \
          --argjson auto_fixed "$autofixed_arr_w" \
          --argjson checks_run "$CHECKS_RUN" --argjson checks_passed "$CHECKS_PASSED" \
        '{ts:$ts, issues:$issues, auto_fixed:$auto_fixed, checks_run:$checks_run, checks_passed:$checks_passed}' \
        > "$CACHE_FILE" 2>/dev/null
} || true

emit_and_exit
